generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model CatalogModel {
  id              String           @id @default(cuid())
  brand           String
  name            String
  series          String?
  year            Int?
  color           String?
  scale           String?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  items           ItemInstance[]
  collectionItems CollectionItem[]
}

model ItemInstance {
  id             String           @id @default(cuid())
  sku            String           @unique
  catalogId      String
  catalog        CatalogModel     @relation(fields: [catalogId], references: [id])
  locationId     String?
  location       StorageLocation? @relation(fields: [locationId], references: [id])
  cardedOrLoose  String
  condition      String
  conditionNotes String?
  purchasePrice  Float?
  listPrice      Float?
  status         String           @default("draft")
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  photos         Photo[]
  listing        Listing?
  orderItems     OrderItem[]
  intakeDraft    IntakeDraft?
}

model Photo {
  id        String       @id @default(cuid())
  itemId    String
  item      ItemInstance @relation(fields: [itemId], references: [id])
  url       String
  type      String
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
}

model StorageLocation {
  id        String         @id @default(cuid())
  label     String
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  items     ItemInstance[]
}

model Listing {
  id          String       @id @default(cuid())
  itemId      String       @unique
  item        ItemInstance @relation(fields: [itemId], references: [id])
  price       Float
  title       String
  description String?
  status      String       @default("active")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  orderItems  OrderItem[]
}

model CustomerProfile {
  id              String            @id @default(cuid())
  email           String            @unique
  name            String?
  phone           String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  orders          Order[]
  sessions        CustomerSession[]
  sellerProfile   SellerProfile?
  collectionItems CollectionItem[]
}

model SellerProfile {
  id             String          @id @default(cuid())
  profileId      String          @unique
  profile        CustomerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  displayName    String?
  status         String          @default("pending")
  commissionRate Float           @default(0.20)
  payoutMethod   String?
  payoutHandle   String?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model CustomerLoginToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
}

model CustomerSession {
  id          String          @id @default(cuid())
  profileId   String
  sessionHash String          @unique
  expiresAt   DateTime
  createdAt   DateTime        @default(now())

  profile CustomerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([expiresAt])
}

model Order {
  id                 String           @id @default(cuid())
  buyerName          String
  buyerEmail         String
  buyerPhone         String?
  status             String           @default("pending")
  notes              String?
  estimatedShipping  Float?
  adminNotes         String?
  followUpNotes      String?
  paymentStatus      String           @default("unpaid")
  paymentMethod      String?
  paymentReference   String?
  paymentLink        String?
  paymentRequestedAt     DateTime?
  paidAt                 DateTime?
  stripeSessionId        String?
  stripeSessionExpiresAt DateTime?
  stripePaymentIntentId  String?
  customerProfileId      String?
  customerProfile        CustomerProfile? @relation(fields: [customerProfileId], references: [id])
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  orderItems             OrderItem[]
}

model OrderItem {
  id        String       @id @default(cuid())
  orderId   String
  order     Order        @relation(fields: [orderId], references: [id])
  itemId    String
  item      ItemInstance @relation(fields: [itemId], references: [id])
  listingId String
  listing   Listing      @relation(fields: [listingId], references: [id])
  price     Float
  createdAt DateTime     @default(now())
}

model CollectionItem {
  id             String               @id @default(cuid())
  profileId      String
  profile        CustomerProfile      @relation(fields: [profileId], references: [id], onDelete: Cascade)

  catalogId      String?
  catalog        CatalogModel?        @relation(fields: [catalogId], references: [id])

  brand          String?
  name           String?
  series         String?
  year           Int?
  color          String?
  scale          String?
  cardedOrLoose  String?
  condition      String?
  conditionNotes String?
  quantity       Int                  @default(1)

  purchasePrice  Float?
  purchaseDate   DateTime?
  notes          String?

  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  photos         CollectionItemPhoto[]
}

model CollectionItemPhoto {
  id        String         @id @default(cuid())
  itemId    String
  item      CollectionItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  url       String
  type      String         @default("other")
  sortOrder Int            @default(0)

  createdAt DateTime       @default(now())
}

model IntakeDraft {
  id              String @id @default(cuid())
  status          String @default("draft")

  frontPhotoUrl   String?
  backPhotoUrl    String?

  brand           String?
  name            String?
  year            Int?
  series          String?
  color           String?
  scale           String?
  cardedOrLoose   String?
  condition       String?
  conditionNotes  String?
  listPrice       Float?
  storageLocation String?
  notes           String?

  convertedItemId String?       @unique
  convertedItem   ItemInstance? @relation(fields: [convertedItemId], references: [id])

  aiExtractionRaw        String?
  aiExtractionNotes      String?
  aiExtractionConfidence Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
