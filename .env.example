# ─────────────────────────────────────────────────────────────────────────────
# .env.example — CollectNTrades / Diecast Inventory MVP
#
# Copy this file to .env.local for local development.
# Never commit a real .env or .env.local file.
# When pasting values into Vercel, paste only the raw value — not the full
# KEY=value line.
# ─────────────────────────────────────────────────────────────────────────────


# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────

# Pooled connection string — used by the app at runtime.
# Get this from the Neon dashboard → Connection Details → Pooled.
# Required for all environments.
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require

# Direct (non-pooled) connection string — used by Prisma for migrations only.
# Get this from the Neon dashboard → Connection Details → Direct.
# Required to run: prisma migrate deploy / prisma db push
DIRECT_URL=postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require


# ── Admin auth ────────────────────────────────────────────────────────────────

# Password for the /admin area.
# An HMAC-SHA256 of this value is stored in an httpOnly session cookie.
# Use a long random string (32+ characters). Changing this invalidates all
# existing admin sessions.
# Required for all environments.
ADMIN_PASSWORD=replace_with_a_long_random_string_32_chars_minimum


# ── Anthropic (AI-assisted inventory intake) ─────────────────────────────────

# API key for the Anthropic API.
# Used by the admin intake flow to extract item fields from photos via Vision.
# If not set, the AI extraction step is skipped silently — the form still works
# but fields will not be pre-filled from photos.
# Optional for local development; required in production for AI intake.
ANTHROPIC_API_KEY=sk-ant-replace_with_real_key

# Anthropic model to use for vision extraction.
# Defaults to claude-haiku-4-5-20251001 if not set.
# Optional.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001


# ── Vercel Blob ───────────────────────────────────────────────────────────────

# Read-write token for Vercel Blob storage.
# Used by the @vercel/blob SDK for photo uploads and deletions in admin intake.
# The SDK reads this automatically — do not reference it manually in code.
# Required for photo upload to work. Without it, uploads will fail.
# Get this from the Vercel dashboard → Storage → Blob → your store → Tokens.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_replace_with_real_token


# ── Stripe ────────────────────────────────────────────────────────────────────

# Stripe secret key (not the publishable key).
# Used server-side to create Checkout Sessions and look up payment intents.
# Use sk_test_... for local/staging; sk_live_... for production.
# Required to generate payment links in the admin order flow.
STRIPE_SECRET_KEY=sk_test_replace_with_real_key

# Stripe webhook signing secret.
# Used to verify that incoming webhook events come from Stripe.
# Get this from: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret.
# Production endpoint: https://www.collectntrades.com/api/webhooks/stripe
# Do NOT use the non-www URL (https://collectntrades.com/api/webhooks/stripe) —
# that domain redirects with HTTP 308, which Stripe does not follow, and webhook
# delivery will fail silently.
# Required for Stripe webhooks to work.
STRIPE_WEBHOOK_SECRET=whsec_replace_with_real_secret


# ── Resend (email) ────────────────────────────────────────────────────────────

# Resend API key.
# Used for: payment link emails, buyer magic-link sign-in emails, admin order digest.
# If not set, magic-link emails are silently skipped (buyer auth still proceeds
# through the form, but no email is sent).
# Required in production for all email features.
RESEND_API_KEY=re_replace_with_real_key

# The verified sender email address used for all outgoing emails.
# Must be a domain/address verified in your Resend account.
# Used for: payment link emails to buyers, magic-link sign-in emails, admin order digest.
# Required for emails to send.
ORDER_DIGEST_FROM_EMAIL=orders@yourdomain.com

# Recipient email for the daily admin order digest.
# This is the address that receives the digest summary each morning.
# Required for the cron digest to deliver.
ORDER_DIGEST_TO_EMAIL=you@yourdomain.com


# ── App URL ───────────────────────────────────────────────────────────────────

# The canonical public URL of the app, with no trailing slash.
# Used to construct magic-link verify URLs, payment confirmation URLs, and
# email link hrefs.
# Production value must be: https://www.collectntrades.com
# Use http://localhost:3000 for local development.
# Required — several email links and redirect URLs depend on this.
APP_URL=http://localhost:3000


# ── Vercel Cron secret ────────────────────────────────────────────────────────

# Secret token that protects the /api/cron/order-digest endpoint.
# Vercel Cron sends this as a Bearer token in the Authorization header.
# The endpoint rejects any request that does not include the correct value.
# Generate a long random string. Set this in Vercel environment variables.
# Required for the cron job to run in production.
CRON_SECRET=replace_with_a_long_random_string


# ── Node environment ──────────────────────────────────────────────────────────

# Set automatically by Vercel in production — do not set it manually there.
# For local development, Next.js sets this to "development" automatically.
# Only set this if you need to override the default locally (e.g. for testing
# production cookie behavior: secure: true).
# NODE_ENV=development
